# Ignore all
*

# but not .dotfiles
!.*
# but not .sh files
!*.sh

# but not .md files
!*.md

# undo ignore for .config
!.config

# undo ignore lua dir
!lua/
!lua/*

# not ignore Templates folder
!/Templates
!/Templates/*.*

.local/share/
.local/lib/
.local/bin/
.local/state/

!ssh.py
!screenshot.png
!00-keyboard.conf
!30-touchpad.conf
!pkglist-intel.txt
!pkglist-nvidia.txt

!Downloads
Downloads/*
!Downloads/Telegram\ Desktop
Downloads/Telegram\ Desktop/*
!Downloads/Telegram\ Desktop/unzip_here.sh

# desktop location changed to "Downloads"
!/.config/user-dirs.dirs

# don't ignore dirs:
# dotf ls-files | xargs dirname | sort -u | sed -e 's/^/!/'
#
!.config/alacritty
!.config/Code/User
